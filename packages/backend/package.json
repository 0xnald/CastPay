{
  "name": "castpay-backend",
  "version": "1.0.0",
  "description": "CastPay - Backend payment verification sidecar",
  "main": "dist/server.js",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc",
    "build:binary": "pkg . --out-path dist/bin",
    "start": "node dist/server.js",
    "generate-wallets": "ts-node src/generate-wallets.ts",
    "test-stream": "ts-node src/test-stream.ts",
    "clean": "rimraf dist"
  },
  "pkg": {
    "assets": [
      "../frontend/dist/**/*"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ]
  },
  "dependencies": {
    "@circle-fin/user-controlled-wallets": "^10.7.1",
    "@circle-fin/x402-batching": "^2.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "viem": "^2.13.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "nodemon": "^3.1.0",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
